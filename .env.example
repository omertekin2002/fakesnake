# Port the server listens on (default: 3000)
PORT=3000

# Set to "production" to serve the prebuilt dist/ instead of the Vite dev server
# NODE_ENV=production

# Allowed CORS origin(s): "*" (default) or a comma-separated allowlist
# ALLOWED_ORIGIN=https://your-app.example.com

# Max simultaneous socket connections per IP (default: 8)
# MAX_CONNECTIONS_PER_IP=8

# Trust the X-Forwarded-For header for the per-IP connection cap. Leave unset
# (off) for a directly-exposed server so clients can't spoof XFF. Set to "true"
# ONLY when running behind a trusted reverse proxy that sets XFF (e.g. Render),
# otherwise every client collapses to the proxy's IP and shares the cap.
# TRUST_PROXY=true
